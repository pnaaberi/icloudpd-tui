#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# icloudpd-tui — Interactive TUI wrapper for iCloud Photos Downloader
#
# Browse your iCloud photo library, check disk space, and selectively
# download photos/videos by year and month using an fzf-based interface.
#
# Version:      0.1.0
# License:      MIT (see LICENSE)
# Repository:   https://github.com/pnaaberi/icloudpd-tui
# Requires:     icloudpd (https://github.com/icloud-photos-downloader/icloud_photos_downloader)
#               fzf (https://github.com/junegunn/fzf)
#               gawk (GNU awk, for asorti/asort)
#
# icloudpd is MIT licensed, Copyright (c) 2016 Nathan Broadbent.
# fzf is MIT licensed, Copyright (c) 2013-2024 Junegunn Choi.
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail
umask 077  # ensure all created files/dirs are owner-only

VERSION="0.1.0"

# ── Config defaults ───────────────────────────────────────────────────────────
# These can be overridden by: config file > env vars > CLI args
# Config file location: ~/.config/icloudpd-tui/config
ICLOUDPD="${ICLOUDPD:-icloudpd}"
USERNAME="${ICLOUD_USERNAME:-}"
TARGET_DIR="${ICLOUD_TARGET_DIR:-}"
MOUNT_POINT="${ICLOUD_MOUNT_POINT:-}"
FOLDER_STRUCTURE="${ICLOUD_FOLDER_STRUCTURE:-{:%Y/%m}}"
DL_SIZE="${ICLOUD_SIZE:-original}"
SCAN_RECENT="${SCAN_RECENT:-500}"

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/icloudpd-tui"
CONFIG_FILE="$CONFIG_DIR/config"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/icloudpd-tui"
CACHE_FILE="$CACHE_DIR/filelist.txt"
CACHE_MAX_AGE=86400  # 24 hours
LIBRARY_TOTAL_FILE="$CACHE_DIR/library_total.txt"  # cached iCloud library size

# Size estimation defaults (KB) — recalibrated from local files if available
AVG_PHOTO_KB=1843    # ~1.8 MB
AVG_VIDEO_KB=30413   # ~29.7 MB

# Known photo/video extensions for classification
PHOTO_EXT='jpg|jpeg|heic|heif|png|webp|avif|tif|tiff|psd|gif|cr2|nef|arw|dng'
VIDEO_EXT='mov|mp4|m4v|avi|mkv'

# ── Dark Forest color palette for fzf ─────────────────────────────────────────
FZF_COLORS="bg:#0d1512,fg:#b0c4c0,hl:#5f8a72,fg+:#d0e8e0,bg+:#162420"
FZF_COLORS+=",hl+:#8fbcaa,pointer:#5f8a72,marker:#8fbcaa,spinner:#5f8a72"
FZF_COLORS+=",header:#3d5c4a,prompt:#5f8a72,border:#3d5c4a,info:#3d5c4a"

# ── ANSI color helpers ────────────────────────────────────────────────────────
_c() { printf '\033[%sm' "$1"; }
_r() { printf '\033[0m'; }
dim()    { printf '%s%s%s' "$(_c '38;2;100;130;115')" "$*" "$(_r)"; }
accent() { printf '%s%s%s' "$(_c '38;2;95;138;114')" "$*" "$(_r)"; }
bold()   { printf '%s%s%s' "$(_c '1')" "$*" "$(_r)"; }
err()    { printf '\033[31m%s\033[0m\n' "$*" >&2; }
info()   { printf '%s %s\n' "$(accent '')" "$*"; }

banner() {
    local g=$'\033[38;2;95;138;114m' b=$'\033[1m' r=$'\033[0m' d=$'\033[38;2;100;130;115m'
    echo "${g}  ╭─────────────────────╮${r}"
    echo "${g}  │${r}${b}  iCloud Photos TUI  ${r}${g}│${r}"
    echo "${g}  ╰─────────────────────╯${r}"
    echo "${d}  Press Ctrl+C at any time to quit safely.${r}"
    echo
}

# Restore terminal state on interrupt
cleanup() {
    tput cnorm 2>/dev/null
    printf '\033[K'
    echo
    info "Stopped. No files were harmed. Run the script again any time."
    exit 0
}
trap cleanup INT TERM

# ── Help ──────────────────────────────────────────────────────────────────────

show_help() {
    cat <<'HELP'
icloudpd-tui — Interactive TUI for iCloud Photos Downloader

USAGE
    icloudpd-tui                  Launch the interactive TUI
    icloudpd-tui <number>         Quick sync (legacy mode, --until-found N)
    icloudpd-tui --help           Show this help
    icloudpd-tui --version        Show version
    icloudpd-tui --setup          Re-run first-time setup

CONFIGURATION
    On first run, you'll be prompted to enter your Apple ID, download
    directory, and mount point. These are saved to:

        ~/.config/icloudpd-tui/config

    You can also set values via environment variables:
        ICLOUD_USERNAME       Apple ID email
        ICLOUD_TARGET_DIR     Local download directory
        ICLOUD_MOUNT_POINT    Mount point to check before downloading
        ICLOUD_FOLDER_STRUCTURE  Folder template (default: {:%Y/%m})
        ICLOUD_SIZE           Image size: original, medium, thumb (default: original)
        SCAN_RECENT           How many recent photos to check (default: 500)

DEPENDENCIES
    icloudpd    https://github.com/icloud-photos-downloader/icloud_photos_downloader
    fzf         https://github.com/junegunn/fzf

# ── Platform detection ─────────────────────────────────────────────────────────

IS_MACOS=false
[[ "$(uname -s)" == "Darwin" ]] && IS_MACOS=true

# macOS ships bash 3.2 which lacks mapfile and associative arrays.
# Auto-relaunch with brew bash if available, otherwise error.
if (( BASH_VERSINFO[0] < 4 )); then
    if $IS_MACOS; then
        for brew_bash in /opt/homebrew/bin/bash /usr/local/bin/bash; do
            if [[ -x "$brew_bash" ]] && "$brew_bash" -c '(( BASH_VERSINFO[0] >= 4 ))' 2>/dev/null; then
                exec "$brew_bash" "$0" "$@"
            fi
        done
        echo "Error: bash 4.0+ is required (you have ${BASH_VERSION})." >&2
        echo "Install with: brew install bash" >&2
    else
        echo "Error: bash 4.0+ is required (you have ${BASH_VERSION})." >&2
    fi
    exit 1
fi

# Portable wrappers for commands that differ between Linux and macOS
file_mtime() {
    if $IS_MACOS; then
        stat -f %m "$1" 2>/dev/null
    else
        stat -c %Y "$1" 2>/dev/null
    fi
}

du_bytes() {
    # Get total size in bytes for a directory
    if $IS_MACOS; then
        # macOS du doesn't have -b; use -k and multiply
        local kb
        kb=$(du -sk "$1" 2>/dev/null | awk '{print $1}') || kb=0
        echo $(( kb * 1024 ))
    else
        du -sb "$1" 2>/dev/null | awk '{print $1}'
    fi
}

df_bytes() {
    # Get disk info in bytes: total used avail percent
    if $IS_MACOS; then
        # macOS df uses 512-byte blocks by default
        df -k "$1" 2>/dev/null | awk 'NR==2{printf "%d %d %d %s\n", $2*1024, $3*1024, $4*1024, $5}'
    else
        df -B1 "$1" 2>/dev/null | awk 'NR==2{printf "%d %d %d %s\n", $2, $3, $4, $5}'
    fi
}

is_mountpoint() {
    # Check if a path is a mount point
    if $IS_MACOS; then
        # On macOS, check if path is listed in mount output
        mount | grep -q " on ${1} " 2>/dev/null
    else
        mountpoint -q "$1" 2>/dev/null
    fi
}

last_day_of_month() {
    # Get the last day of a given YYYY MM (handles leap years)
    if $IS_MACOS; then
        # macOS date: go to 1st of next month, subtract 1 day
        local next_mo next_yr
        next_mo=$(( 10#$2 + 1 ))
        next_yr=$1
        if (( next_mo > 12 )); then next_mo=1; next_yr=$(( next_yr + 1 )); fi
        date -j -f "%Y-%m-%d" "$(printf '%04d-%02d-01' "$next_yr" "$next_mo")" -v-1d "+%d" 2>/dev/null
    else
        date -d "$1-$2-01 +1 month -1 day" +%d
    fi
}

# ── Dependency checks ─────────────────────────────────────────────────────────

check_deps() {
    local missing=()
    command -v "$ICLOUDPD" &>/dev/null || missing+=("icloudpd")
    command -v fzf &>/dev/null         || missing+=("fzf")
    command -v gawk &>/dev/null        || missing+=("gawk (brew install gawk)")
    command -v tput &>/dev/null        || missing+=("ncurses (tput)")

    if (( ${#missing[@]} > 0 )); then
        err "Missing required dependencies:"
        for dep in "${missing[@]}"; do
            err "  - $dep"
        done
        err ""
        err "Install them and try again."
        exit 1
    fi
}

# ── Config loading & first-run setup ──────────────────────────────────────────

load_config() {
    # Source config file if it exists
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck source=/dev/null
        source "$CONFIG_FILE"
    fi
}

save_config() {
    mkdir -p "$CONFIG_DIR" && chmod 700 "$CONFIG_DIR"
    # Use printf %q to safely escape values for shell sourcing
    cat > "$CONFIG_FILE" <<EOF
# icloudpd-tui configuration
# Generated on $(date +%Y-%m-%d)

# Apple ID email address
USERNAME=$(printf '%q' "$USERNAME")

# Local directory to download photos into
TARGET_DIR=$(printf '%q' "$TARGET_DIR")

# Mount point to verify before downloading (parent of TARGET_DIR)
MOUNT_POINT=$(printf '%q' "$MOUNT_POINT")

# Folder structure template (default: {:%Y/%m})
FOLDER_STRUCTURE=$(printf '%q' "$FOLDER_STRUCTURE")

# Image size to download: original, medium, thumb
DL_SIZE=$(printf '%q' "$DL_SIZE")
EOF
    chmod 600 "$CONFIG_FILE"  # restrict permissions — contains Apple ID
    info "Config saved to $CONFIG_FILE"
}

run_setup() {
    echo
    accent "  Welcome! Let's set up your iCloud photo backup."; echo
    dim "  This takes about a minute. Your settings stay on this computer."; echo
    echo
    # Animate the steps roadmap — white sweep across, fades to dim, flash twice
    local full_line="1) Apple ID  →  2) Download location  →  3) Login test"
    local d=$'\033[38;2;100;130;115m' w=$'\033[1;37m' r=$'\033[0m'
    local len=${#full_line}

    # Sweep: ~4 seconds
    local i=0
    while (( i < len )); do
        printf '\r  %s%s%s%s%s%s' "$d" "${full_line:0:i}" "$w" "${full_line:i:1}" "$r" "$d"
        i=$((i + 1))
        sleep 0.05
    done

    # Flash twice
    for f in 1 2; do
        sleep 0.2
        printf '\r  %s%s%s' "$w" "$full_line" "$r"
        sleep 0.15
        printf '\r  %s%s%s' "$d" "$full_line" "$r"
    done
    echo
    echo

    # ── Step 1: Apple ID ──────────────────────────────────────────────────────
    local input
    accent "  Step 1 of 3 — Apple ID"; echo
    echo "  ────────────────────────────────────"
    dim "  Enter the email address for your iCloud account."; echo
    echo

    local default_user="$USERNAME"
    dim "  Tip: you can paste your email with Cmd+V or Ctrl+Shift+V"; echo
    echo
    while true; do
        read -erp "  Apple ID${default_user:+ [$default_user]}: " input
        input="${input:-$default_user}"
        if [[ "$input" == *@*.* ]]; then
            USERNAME="$input"
            break
        elif [[ -z "$input" ]]; then
            err "  Apple ID is required."
        else
            err "  That doesn't look like an email. You can copy-paste it instead."
        fi
    done
    echo

    # ── Step 2: Download location ─────────────────────────────────────────────
    accent "  Step 2 of 3 — Download location"; echo
    echo "  ────────────────────────────────────"
    dim "  Where should photos be saved? This can be an external"; echo
    dim "  drive or any folder on your computer."; echo
    echo

    local default_dir="${TARGET_DIR:-$HOME/icloud-photos}"
    dim "  Press Enter to use the default, or type a new path (Tab to autocomplete)"; echo
    read -erp "  Directory [$default_dir]: " input
    TARGET_DIR="${input:-$default_dir}"
    TARGET_DIR="${TARGET_DIR/#\~/$HOME}"  # expand ~

    if [[ ! -d "$TARGET_DIR" ]]; then
        dim "  Directory doesn't exist yet."; echo
        read -rp "  Create it? [Y/n] " input
        case "$input" in
            [nN]*) err "  Can't continue without a download directory."; exit 1 ;;
            *)
                if ! mkdir -p "$TARGET_DIR" 2>/dev/null; then
                    err "  Could not create directory (permission denied?)."
                    err "  Check the path and try again."
                    echo
                    read -erp "  Directory: " input
                    TARGET_DIR="${input:-$TARGET_DIR}"
                    TARGET_DIR="${TARGET_DIR/#\~/$HOME}"
                    if [[ ! -d "$TARGET_DIR" ]]; then
                        mkdir -p "$TARGET_DIR" || { err "  Still can't create it. Exiting."; exit 1; }
                    fi
                fi
                info "Created $TARGET_DIR"
                ;;
        esac
    fi
    echo

    # ── Step 3: Drive check ───────────────────────────────────────────────────
    # Auto-detect if TARGET_DIR is on an external/removable drive
    local detected_drive=""
    local df_mount
    df_mount=$(df "$TARGET_DIR" 2>/dev/null | awk 'NR==2{print $6}')
    if [[ "$df_mount" == /run/media/* || "$df_mount" == /mnt/* || "$df_mount" == /media/* || "$df_mount" == /Volumes/* ]]; then
        detected_drive="$df_mount"
    fi

    if [[ -n "$detected_drive" ]]; then
        # External drive detected — confirm with user
        accent "  Step 3 of 3 — External drive detected"; echo
        echo "  ────────────────────────────────────"
        printf "  Your photos are saved on: %s\n" "$(bold "$detected_drive")"
        dim "  We can check this drive is plugged in before each download,"; echo
        dim "  so you don't get errors if it's disconnected."; echo
        echo
        read -rp "  Enable this check? [Y/n] " input
        case "$input" in
            [nN]*) MOUNT_POINT="" ;;
            *)     MOUNT_POINT="$detected_drive" ;;
        esac
    else
        # Local folder — skip silently
        MOUNT_POINT=""
    fi
    echo

    # ── Summary ───────────────────────────────────────────────────────────────
    accent "  Summary"; echo
    echo "  ────────────────────────────────────"
    printf "  Apple ID:      %s\n" "$(bold "$USERNAME")"
    printf "  Directory:     %s\n" "$(bold "$TARGET_DIR")"
    if [[ -n "$MOUNT_POINT" ]]; then
        printf "  Drive check:   %s\n" "$(bold "$MOUNT_POINT")"
    fi
    echo "  ────────────────────────────────────"
    echo

    read -rp "  Save and test iCloud login? [Y/n] " input
    case "$input" in
        [nN]*) err "  Setup cancelled."; exit 0 ;;
    esac

    echo
    save_config

    # ── Auth test ─────────────────────────────────────────────────────────────
    echo
    info "Testing iCloud login..."
    dim "  You may be asked for your password and a verification code."; echo
    echo
    if "$ICLOUDPD" --auth-only --username "$USERNAME"; then
        echo
        info "Setup complete!"
        SETUP_AUTH_DONE=true
    else
        echo
        err "  Login failed — but your settings are saved."
        err "  You can fix this later by running: icloudpd-tui --setup"
        SETUP_AUTH_DONE=false
    fi
    echo
}

ensure_config() {
    load_config

    # Check if required values are set (mount point is optional)
    if [[ -z "$USERNAME" || -z "$TARGET_DIR" ]]; then
        banner
        run_setup
        # Don't exit — continue into the main menu
    fi

    if [[ ! -d "$TARGET_DIR" ]]; then
        mkdir -p "$TARGET_DIR" 2>/dev/null || true
        info "Created download directory: $TARGET_DIR"
    fi
}

# ── Utilities ─────────────────────────────────────────────────────────────────

check_mount() {
    # Skip check if no mount point configured (local folder setup)
    [[ -z "$MOUNT_POINT" ]] && return 0

    if ! is_mountpoint "$MOUNT_POINT" 2>/dev/null; then
        err "Backup drive not found."
        err "Please plug in the drive and make sure it appears at:"
        err "  $MOUNT_POINT"
        err "Then run this script again."
        exit 1
    fi
}

# Convert bytes to human-readable format using pure bash integer arithmetic
humanize() {
    local bytes=${1:-0}
    [[ "$bytes" =~ ^[0-9]+$ ]] || bytes=0
    if (( bytes >= 1099511627776 )); then
        local tb10=$(( bytes * 10 / 1099511627776 ))
        printf "%d.%d TB" "$(( tb10 / 10 ))" "$(( tb10 % 10 ))"
    elif (( bytes >= 1073741824 )); then
        local gb10=$(( bytes * 10 / 1073741824 ))
        printf "%d.%d GB" "$(( gb10 / 10 ))" "$(( gb10 % 10 ))"
    elif (( bytes >= 1048576 )); then
        local mb10=$(( bytes * 10 / 1048576 ))
        printf "%d.%d MB" "$(( mb10 / 10 ))" "$(( mb10 % 10 ))"
    else
        local kb10=$(( bytes * 10 / 1024 ))
        printf "%d.%d KB" "$(( kb10 / 10 ))" "$(( kb10 % 10 ))"
    fi
}

# Populate DISK_TOTAL, DISK_USED, DISK_AVAIL, DISK_PCT globals
disk_info() {
    local info
    info=$(df_bytes "$TARGET_DIR")
    DISK_TOTAL=$(echo "$info" | awk '{print $1}')
    DISK_USED=$(echo "$info" | awk '{print $2}')
    DISK_AVAIL=$(echo "$info" | awk '{print $3}')
    DISK_PCT=$(echo "$info" | awk '{print $4}')
}

# Estimate total download size in MB from file counts and average sizes
estimate_size_mb() {
    local photos=$1 videos=$2
    local kb=$(( photos * AVG_PHOTO_KB + videos * AVG_VIDEO_KB ))
    echo $(( kb / 1024 ))
}

# Compute real average file sizes from already-downloaded files
calibrate_averages() {
    if [[ ! -d "$TARGET_DIR" ]]; then return; fi
    # Portable: find + ls -l works on both Linux and macOS
    local result
    result=$(find "$TARGET_DIR" -type f -exec ls -ln {} + 2>/dev/null | gawk -v pext="$PHOTO_EXT" -v vext="$VIDEO_EXT" '
    {
        sz = $5
        fn = $NF; sub(/.*\//, "", fn)
        n = split(fn, parts, ".")
        ext = tolower(parts[n])
        if (ext ~ "^(" pext ")$") { psz += sz; pc++ }
        else if (ext ~ "^(" vext ")$") { vsz += sz; vc++ }
    }
    END {
        pavg_kb = (pc > 0) ? int(psz / pc / 1024) : 0
        vavg_kb = (vc > 0) ? int(vsz / vc / 1024) : 0
        printf "%d %d %d %d\n", pc, vc, pavg_kb, vavg_kb
    }')
    local pc vc pavg vavg
    read -r pc vc pavg vavg <<< "$result"
    if (( pc > 100 )); then AVG_PHOTO_KB=$pavg; fi
    if (( vc > 20 )); then AVG_VIDEO_KB=$vavg; fi
}

# Interactive directory picker using fzf.
# Shows the default path first, plus common locations (external drives, home).
# User picks with Enter or presses Esc to cancel.
# Usage: dir=$(pick_directory "/current/default") || return
pick_directory() {
    local default_dir="$1"
    local user=${USER:-$(whoami)}

    # Build list of candidate directories from common locations
    local -a dirs=()
    [[ -d "$default_dir" ]] && dirs+=("$default_dir  (current)")

    # External/removable drives — varies by distro
    # Arch/Fedora: /run/media/$USER, Ubuntu/Debian: /media/$USER
    for base in "/run/media/$user" "/media/$user"; do
        if [[ -d "$base" ]]; then
            for d in "$base"/*/; do
                [[ -d "$d" ]] && dirs+=("${d%/}")
            done
        fi
    done

    # Manual mount points (Linux)
    for d in /mnt/*/; do [[ -d "$d" ]] && dirs+=("${d%/}"); done

    # macOS volumes
    if $IS_MACOS; then
        for d in /Volumes/*/; do
            [[ -d "$d" && "$d" != "/Volumes/Macintosh HD/" ]] && dirs+=("${d%/}")
        done
    fi

    # Common home directories for photos
    for d in "$HOME/Pictures" "$HOME/Photos" "$HOME/icloud-photos"; do
        [[ -d "$d" ]] && dirs+=("$d")
    done

    # Home directory itself
    dirs+=("$HOME")

    # Deduplicate — current dir might also be found in scanned paths
    local -a unique_dirs=()
    local -A seen=()
    for d in "${dirs[@]}"; do
        local clean="${d%  (current)}"
        [[ -n "${seen[$clean]:-}" ]] && continue
        seen["$clean"]=1
        unique_dirs+=("$d")
    done
    dirs=("${unique_dirs[@]}")

    # Add free space info to each entry
    local -a display=()
    for d in "${dirs[@]}"; do
        local clean="${d%  (current)}"
        local is_current=""
        [[ "$d" == *"(current)"* ]] && is_current=" (current)"
        if [[ -d "$clean" ]]; then
            local free
            free=$(df -h "$clean" 2>/dev/null | awk 'NR==2{print $4}') || free="?"
            display+=("$(printf '%s\t%s free%s' "$clean" "$free" "$is_current")")
        fi
    done

    local header
    header=$(printf '  %s\n  %s\n  %s\n  %s' \
        "$(accent "Where should files be saved?")" \
        "$(dim "Files will be organized as: <directory>/YYYY/MM/photo.jpg")" \
        "$(dim "Select a directory, or type a custom path")" \
        "$(dim "Esc = keep current location")")

    # --print-query outputs the typed query on line 1 and the selected match on line 2.
    # If the user types a custom path that doesn't match, line 2 is empty — we use line 1.
    local result rc=0
    result=$(printf '%s\n' "${display[@]}" | fzf --ansi --no-multi --no-sort --reverse \
        --color="$FZF_COLORS" \
        --prompt="  path: " --pointer="▸" \
        --print-query --delimiter='\t' --with-nth=1.. \
        --header="$header" \
        --header-first \
    2>/dev/null) || rc=$?

    # Esc = exit code 130, no match = 1, match = 0
    if (( rc == 130 )) || [[ -z "$result" ]]; then
        echo "$default_dir"
        return 0
    fi

    local query selected
    query=$(echo "$result" | sed -n '1p')
    selected=$(echo "$result" | sed -n '2p')

    # Prefer the matched selection; fall back to typed query
    local chosen
    if [[ -n "$selected" ]]; then
        # Extract path (everything before the tab separator)
        chosen=$(echo "$selected" | cut -f1)
    elif [[ -n "$query" ]]; then
        # User typed a custom path
        chosen="${query/#\~/$HOME}"
    else
        echo "$default_dir"
        return 0
    fi

    # Create directory if it doesn't exist
    if [[ ! -d "$chosen" ]]; then
        printf "  Directory %s doesn't exist.\n" "$(bold "$chosen")" > /dev/tty
        read -rp "  Create it? [Y/n] " create < /dev/tty
        case "$create" in
            [nN]*) echo "$default_dir"; return 0 ;;
            *)
                if ! mkdir -p "$chosen" 2>/dev/null; then
                    err "  Could not create directory (permission denied?)." > /dev/tty
                    echo "$default_dir"
                    return 0
                fi
                info "Created $chosen" > /dev/tty
                ;;
        esac
    fi

    echo "$chosen"
}

# Estimate bytes needed for N missing files based on local backup average.
estimate_missing_bytes() {
    local missing_count=$1
    local local_count
    local_count=$(find "$TARGET_DIR" -type f 2>/dev/null | wc -l)
    if (( local_count < 100 )); then
        echo $(( missing_count * 5 * 1048576 ))
        return
    fi
    local total_bytes
    total_bytes=$(du_bytes "$TARGET_DIR")
    local avg_bytes=$(( total_bytes / local_count ))
    echo $(( missing_count * avg_bytes ))
}



# ── Scan / Cache ──────────────────────────────────────────────────────────────

ensure_cache() { mkdir -p "$CACHE_DIR" && chmod 700 "$CACHE_DIR"; }

# Save the iCloud library total when we see it in icloudpd output.
# icloudpd prints "Downloading N original photos and videos" on every run.
capture_library_total() {
    local log_file=$1
    local total
    total=$(grep -o 'Downloading [0-9]* original' "$log_file" 2>/dev/null | grep -o '[0-9]*' | head -1) || total=""
    if [[ -n "$total" && "$total" -gt 0 ]]; then
        echo "$total" > "$LIBRARY_TOTAL_FILE"
    fi
}

get_library_total() {
    if [[ -f "$LIBRARY_TOTAL_FILE" ]]; then
        cat "$LIBRARY_TOTAL_FILE"
    else
        echo ""
    fi
}

cache_is_fresh() {
    [[ -f "$CACHE_FILE" ]] || return 1
    local now mtime age
    now=$(date +%s)
    mtime=$(file_mtime "$CACHE_FILE") || mtime=0
    age=$(( now - mtime ))
    (( age < CACHE_MAX_AGE ))
}

# Animated spinner that runs while a background process works.
# All display output goes to /dev/tty so that $() capture only gets the count.
# Monitors: file line count, log file mtime, and /proc CPU usage for stall detection.
spin_while() {
    local pid=$1 counter_file=$2 msg=$3 log_file=${4:-} timeout=${5:-900}
    local frames='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    local i=0 count=0 prev_count=0 last_log=""
    local start_ts elapsed_s stall_start
    start_ts=$(date +%s)
    stall_start=$start_ts
    local stall_timeout=600

    local tty=/dev/tty
    tput civis > "$tty" 2>/dev/null || true

    printf '  \033[38;2;95;138;114m%s\033[0m %s' "${frames:0:1}" "$msg" > "$tty"

    while kill -0 "$pid" 2>/dev/null; do
        count=$(wc -l < "$counter_file" 2>/dev/null) || count=0
        local now_ts
        now_ts=$(date +%s)
        elapsed_s=$(( now_ts - start_ts ))

        # Reset stall timer when new files appear or log changes
        if (( count != prev_count )); then
            stall_start=$now_ts
            prev_count=$count
        elif [[ -n "$log_file" && -s "$log_file" ]]; then
            local log_mtime
            log_mtime=$(file_mtime "$log_file" 2>/dev/null) || log_mtime=0
            if (( log_mtime > stall_start )); then
                stall_start=$now_ts
            fi
        fi
        # Check if process is still consuming CPU (Linux-specific)
        if [[ -f "/proc/$pid/stat" ]]; then
            local cpu_time
            cpu_time=$(gawk '{print $14+$15}' "/proc/$pid/stat" 2>/dev/null) || cpu_time=0
            if [[ -z "${prev_cpu:-}" ]]; then prev_cpu=$cpu_time; fi
            if (( cpu_time > prev_cpu )); then
                stall_start=$now_ts
                prev_cpu=$cpu_time
            fi
        fi

        # Kill if stalled
        local stall_secs=$(( now_ts - stall_start ))
        if (( stall_secs >= stall_timeout )); then
            kill "$pid" 2>/dev/null || true
            wait "$pid" 2>/dev/null || true
            printf '\r\033[K' > "$tty"
            tput cnorm > "$tty" 2>/dev/null || true
            err "  Timed out: no response from iCloud for ${stall_timeout}s."
            err "  This can happen if your session expired or the network is down."
            err "  Try running the script again — it will re-authenticate."
            echo "0"
            return 1
        fi

        # Kill if total timeout exceeded
        if (( elapsed_s >= timeout )); then
            kill "$pid" 2>/dev/null || true
            wait "$pid" 2>/dev/null || true
            printf '\r\033[K' > "$tty"
            tput cnorm > "$tty" 2>/dev/null || true
            err "  Scan timed out after $(( timeout / 60 ))m. Try again later."
            echo "0"
            return 1
        fi

        # Format elapsed time for display
        local elapsed_fmt
        if (( elapsed_s >= 60 )); then
            elapsed_fmt="$(( elapsed_s / 60 ))m$(( elapsed_s % 60 ))s"
        else
            elapsed_fmt="${elapsed_s}s"
        fi

        if [[ -n "$log_file" && -s "$log_file" ]]; then
            last_log=$(tail -1 "$log_file" 2>/dev/null | sed 's/^[0-9T:.Z -]*//' | cut -c1-50) || last_log=""
        fi

        local status_str
        if (( count > 0 )); then
            status_str="\033[1m${count}\033[0m files"
        else
            status_str="\033[2mquerying library...\033[0m"
        fi

        printf '\r\033[K  \033[38;2;95;138;114m%s\033[0m %s %b \033[2m[%s]\033[0m  \033[2m%s\033[0m' \
            "${frames:i%${#frames}:1}" "$msg" "$status_str" "$elapsed_fmt" "$last_log" > "$tty"
        i=$((i + 1))
        sleep 0.08
    done

    wait "$pid" 2>/dev/null || true
    count=$(wc -l < "$counter_file" 2>/dev/null) || count=0
    printf '\r\033[K' > "$tty"
    tput cnorm > "$tty" 2>/dev/null || true
    echo "$count"
}

# Quick scan using --recent N (full library scan is too slow for large libraries).
# The tree view is built from local files; this only finds NEW files.
scan_library() {
    ensure_cache
    > "$CACHE_FILE"
    local log_file="$CACHE_DIR/scan.log"
    > "$log_file"

    local recent=$SCAN_RECENT
    "$ICLOUDPD" \
        --only-print-filenames \
        --log-level info \
        --username "$USERNAME" \
        --directory "$TARGET_DIR" \
        --folder-structure "$FOLDER_STRUCTURE" \
        --size "$DL_SIZE" \
        --recent "$recent" \
        >> "$CACHE_FILE" 2>>"$log_file" &
    local pid=$!
    BG_PID=$pid

    local count
    if count=$(spin_while "$pid" "$CACHE_FILE" "Checking for new files (last $recent)..." "$log_file" 120); then
        BG_PID=""
        if (( count > 0 )); then
            info "Found $count new files to download"
        else
            info "Everything is up to date"
        fi
    else
        BG_PID=""
        return 1
    fi
}


# Build a year/month tree from local files + pending (new) files from cache.
# Output format: TYPE|YEAR|MONTH|PHOTOS|VIDEOS|PENDING_PHOTOS|PENDING_VIDEOS
# TYPE: Y = year summary row, M = month detail row
build_tree() {
    local tree_file="$CACHE_DIR/tree.txt"
    {
        if [[ -d "$TARGET_DIR" ]]; then
            find "$TARGET_DIR" -type f 2>/dev/null | gawk -v prefix="$TARGET_DIR/" '{if (index($0,prefix)==1) print substr($0, length(prefix)+1); else print}'
        fi
    } | gawk -v pext="$PHOTO_EXT" -v vext="$VIDEO_EXT" -v cache="$CACHE_FILE" -v tdir="$TARGET_DIR" '
    BEGIN {
        # Read pending (not yet downloaded) files from the scan cache
        while ((getline line < cache) > 0) {
            # Strip the target directory prefix to get YYYY/MM/filename
            if (index(line, tdir "/") == 1) line = substr(line, length(tdir) + 2)
            n = split(line, parts, "/")
            if (n < 3) continue
            yr = parts[1]; mo = parts[2]; fn = parts[n]
            en = split(fn, ep, ".")
            ext = tolower(ep[en])
            key = yr "/" mo
            if (ext ~ "^(" pext ")$") { pending_p[key]++ }
            else if (ext ~ "^(" vext ")$") { pending_v[key]++ }
        }
        close(cache)
    }
    {
        # Process local (already downloaded) files
        n = split($0, parts, "/")
        if (n < 3) next
        yr = parts[1]; mo = parts[2]; fn = parts[n]
        en = split(fn, ep, ".")
        ext = tolower(ep[en])
        key = yr "/" mo
        if (ext ~ "^(" pext ")$") { photos[key]++ }
        else if (ext ~ "^(" vext ")$") { videos[key]++ }
        years[yr] = 1
        months[key] = 1
    }
    END {
        # Include keys from pending files that may not exist locally yet
        for (k in pending_p) { months[k] = 1; split(k, _kp, "/"); years[_kp[1]] = 1 }
        for (k in pending_v) { months[k] = 1; split(k, _kp, "/"); years[_kp[1]] = 1 }

        # Output rows sorted by year (descending) then month (ascending)
        n = asorti(years, syears)
        for (i = n; i >= 1; i--) {
            yr = syears[i]
            yp = 0; yv = 0; ypp = 0; ypv = 0
            mc = 0
            for (k in months) {
                split(k, kp, "/")
                if (kp[1] == yr) { mc++; mlist[mc] = kp[2] }
            }
            asort(mlist)
            for (j = mc; j >= 1; j--) {
                mo = mlist[j]
                key = yr "/" mo
                p = photos[key]+0; v = videos[key]+0
                pp = pending_p[key]+0; pv = pending_v[key]+0
                yp += p + pp; yv += v + pv; ypp += pp; ypv += pv
                printf "M|%s|%s|%d|%d|%d|%d\n", yr, mo, p+pp, v+pv, pp, pv
            }
            printf "Y|%s|--|%d|%d|%d|%d\n", yr, yp, yv, ypp, ypv
            delete mlist
        }
    }
    ' > "$tree_file"

    echo "$tree_file"
}

# Format tree data as ANSI-colored lines for fzf display
format_tree() {
    local tree_file=$1
    gawk -F'|' -v pavg="$AVG_PHOTO_KB" -v vavg="$AVG_VIDEO_KB" '
    function humanize(kb) {
        mb = kb / 1024
        if (mb >= 1024) return sprintf("%.1f GB", mb/1024)
        return sprintf("%.0f MB", mb)
    }
    {
        type=$1; yr=$2; mo=$3; photos=$4; videos=$5; pp=$6; pv=$7
        pending = pp + pv
        est_kb = pp * pavg + pv * vavg
        est = humanize(est_kb)

        if (type == "Y") {
            printf "\033[1m%-10s\033[0m \033[2m│\033[0m %6d photos \033[2m│\033[0m %5d videos \033[2m│\033[0m \033[38;2;95;138;114m%5d new\033[0m \033[2m│ ~%s\033[0m\n",
                yr, photos, videos, pending, est
        } else {
            printf "    \033[2m%-6s\033[0m \033[2m│\033[0m %6d photos \033[2m│\033[0m %5d videos \033[2m│\033[0m \033[38;2;95;138;114m%5d new\033[0m \033[2m│ ~%s\033[0m\n",
                yr "/" mo, photos, videos, pending, est
        }
    }
    ' "$tree_file"
}

# ── TUI ───────────────────────────────────────────────────────────────────────

main_menu() {
    # Build status summary for the header
    local status_lines=""
    local local_count=0 pending_count=0

    if [[ -d "$TARGET_DIR" ]]; then
        local_count=$(find "$TARGET_DIR" -type f 2>/dev/null | wc -l)
    fi
    if [[ -f "$CACHE_FILE" ]]; then
        pending_count=$(wc -l < "$CACHE_FILE")
    fi

    local library_total
    library_total=$(get_library_total)

    status_lines+="$(dim "  ────────────────────────────────────")"$'\n'
    status_lines+="  $(dim "Account:")  $(bold "$USERNAME")"$'\n'

    if [[ "$library_total" =~ ^[0-9]+$ ]] && (( library_total > 0 )); then
        local pct=$(( local_count * 100 / library_total ))
        local missing=$(( library_total - local_count ))
        status_lines+="  $(dim "Backup:")   $(bold "$local_count") of ~$(bold "$library_total") iCloud files (${pct}%)"$'\n'
        if (( missing > 100 )); then
            local est_bytes
            est_bytes=$(estimate_missing_bytes "$missing")
            local est_human
            est_human=$(humanize "$est_bytes")
            status_lines+=$'  \033[33m'"           ~${missing} files not backed up (~${est_human} needed)"$'\033[0m\n'
        elif (( missing > 0 )); then
            status_lines+="  $(dim "           ~${missing} files remaining")"$'\n'
        fi
    else
        status_lines+="  $(dim "Backup:")   $(bold "$local_count") files in $(dim "$TARGET_DIR")"$'\n'
        status_lines+="  $(dim "           Run a sync to detect your iCloud library size")"$'\n'
    fi

    if (( pending_count > 0 )); then
        status_lines+="  $(dim "New:")      $(accent "$pending_count files") waiting to download"$'\n'
    fi

    if [[ -d "$TARGET_DIR" ]]; then
        disk_info
        # Warn based on absolute free space, not percentage (60GB on a 1TB drive is fine)
        local avail_gb=$(( DISK_AVAIL / 1073741824 ))
        if (( avail_gb < 2 )); then
            status_lines+=$'  \033[31m'"Disk:     $(humanize "$DISK_AVAIL") free of $(humanize "$DISK_TOTAL") — almost full!"$'\033[0m\n'
        elif (( avail_gb < 10 )); then
            status_lines+="  $(dim "Disk:")     $(bold "$(humanize "$DISK_AVAIL")") free of $(humanize "$DISK_TOTAL")  $(dim "⚠ running low")"$'\n'
        else
            status_lines+="  $(dim "Disk:")     $(humanize "$DISK_AVAIL") free of $(humanize "$DISK_TOTAL")"$'\n'
        fi
    fi
    status_lines+="$(dim "  ────────────────────────────────────")"$'\n'
    status_lines+=$'\n'
    status_lines+="$(dim "  Use arrow keys ↑↓ to move, Enter to select, Esc to quit")"

    local choice
    choice=$(printf '%s\n' \
        "  Sync                 Download new and missing files from iCloud" \
        "  Browse Library       View your backup organized by year and month" \
        "  Download by Date     Pick specific months to re-sync from iCloud" \
        "  Disk Status          Check backup drive space and storage estimates" \
        "  Settings             Change Apple ID, download location, or drive" \
        "  Log Out              Clear iCloud session and credentials" \
        "  Quit                 Exit the program" \
    | fzf --ansi --no-multi --no-sort --reverse \
        --color="$FZF_COLORS" \
        --prompt="  " --pointer="▸" \
        --header="$status_lines" \
        --header-first \
    || echo "Quit")

    case "$choice" in
        *"Sync"*)              action_sync ;;
        *"Browse Library"*)    action_browse_library ;;
        *"Download by Date"*)  action_download_by_date ;;
        *"Disk Status"*)       action_disk_status ;;
        *"Settings"*)          action_settings ;;
        *"Log Out"*)           action_logout ;;
        *)                      info "Bye."; exit 0 ;;
    esac
}

# View-only: show library tree, no download
action_browse_library() {
    calibrate_averages
    local tree_file
    tree_file=$(build_tree)

    disk_info
    local total_local
    total_local=$(find "$TARGET_DIR" -type f 2>/dev/null | wc -l)

    local header
    header=$(printf '  %s\n  %s files backed up  |  Disk: %s free of %s\n\n  %s\n  %s' \
        "$(accent "Your iCloud backup — what is already saved on this drive")" \
        "$(bold "$total_local")" \
        "$(humanize "$DISK_AVAIL")" "$(humanize "$DISK_TOTAL")" \
        "$(dim "Scroll with arrow keys ↑↓  |  Esc = go back")" \
        "$(dim "To download, use 'Sync' or 'Download by Date' from the menu")")

    # View-only: no --multi, just browsing
    format_tree "$tree_file" | fzf --ansi --no-multi --no-sort --reverse \
        --color="$FZF_COLORS" \
        --prompt="  " --pointer="▸" \
        --header="$header" \
        --header-first \
    || true

    main_menu
}

# Select year/month folders and download them from iCloud
action_download_by_date() {
    calibrate_averages
    local tree_file
    tree_file=$(build_tree)

    disk_info

    local header
    header=$(printf '  %s\n  %s\n  Disk: %s free of %s\n\n  %s\n  %s\n  %s\n  %s' \
        "$(accent "Select time periods to re-sync from iCloud")" \
        "$(dim "icloudpd will download any files missing from your backup for the selected months.")" \
        "$(humanize "$DISK_AVAIL")" "$(humanize "$DISK_TOTAL")" \
        "$(dim "1. Use Tab to mark folders you want to download")" \
        "$(dim "2. Press Enter to continue to download options")" \
        "$(dim "3. Selecting a year row selects all its months")" \
        "$(dim "Esc = go back    Ctrl-A = select all")")

    local selection
    selection=$(format_tree "$tree_file" | fzf --ansi --multi --no-sort --reverse \
        --color="$FZF_COLORS" \
        --prompt="  " --pointer="▸" --marker="+" \
        --header="$header" \
        --header-first \
        --bind='ctrl-a:select-all,ctrl-d:deselect-all' \
    || true)

    if [[ -z "$selection" ]]; then
        info "No selection made."
        main_menu
        return
    fi

    # Parse fzf selection into YYYY/MM keys, expanding year rows to all months
    local -a selected_months=()
    while IFS= read -r line; do
        local trimmed key
        trimmed=$(echo "$line" | sed 's/\x1b\[[0-9;]*m//g' | xargs)
        key=$(echo "$trimmed" | awk '{print $1}')

        if [[ "$key" =~ ^[0-9]{4}$ ]]; then
            while IFS='|' read -r type yr mo _ _ _ _; do
                if [[ "$type" == "M" && "$yr" == "$key" ]]; then
                    selected_months+=("$yr/$mo")
                fi
            done < "$tree_file"
        elif [[ "$key" =~ ^[0-9]{4}/[0-9]{2}$ ]]; then
            selected_months+=("$key")
        fi
    done <<< "$selection"

    if [[ ${#selected_months[@]} -eq 0 ]]; then
        info "No valid folders selected."
        main_menu
        return
    fi

    mapfile -t selected_months < <(printf '%s\n' "${selected_months[@]}" | sort -u)

    local type_filter
    type_filter=$(type_filter_menu)

    confirm_download "${selected_months[@]}" "$type_filter"
}

type_filter_menu() {
    local choice
    choice=$(printf '%s\n' \
        "  All files        Photos + videos" \
        "  Photos only      Skip videos" \
        "  Videos only      Skip photos" \
    | fzf --ansi --no-multi --no-sort --reverse \
        --color="$FZF_COLORS" \
        --prompt="  " --pointer="▸" \
        --header="$(printf '  %s\n  %s' \
            "$(accent "What to download?")" \
            "$(dim "Use arrow keys ↑↓ to pick, Enter to confirm, Esc for all files")")" \
        --header-first \
    || echo "All files")

    case "$choice" in
        *"Photos only"*) echo "photos" ;;
        *"Videos only"*) echo "videos" ;;
        *)               echo "all" ;;
    esac
}

confirm_download() {
    local -a months=("${@:1:$#-1}")
    local type_filter="${*: -1}"

    local tree_file="$CACHE_DIR/tree.txt"
    local total_pp=0 total_pv=0
    for m in "${months[@]}"; do
        local yr mo
        yr="${m%%/*}"; mo="${m##*/}"
        while IFS='|' read -r type tyr tmo _ _ pp pv; do
            if [[ "$type" == "M" && "$tyr" == "$yr" && "$tmo" == "$mo" ]]; then
                total_pp=$((total_pp + pp))
                total_pv=$((total_pv + pv))
            fi
        done < "$tree_file"
    done

    local dl_photos=$total_pp dl_videos=$total_pv
    case "$type_filter" in
        photos) dl_videos=0 ;;
        videos) dl_photos=0 ;;
    esac

    local est_mb
    est_mb=$(estimate_size_mb "$dl_photos" "$dl_videos")

    disk_info

    TARGET_DIR=$(pick_directory "$TARGET_DIR") || { main_menu; return; }

    echo
    accent "  Download Summary"; echo
    echo "  ────────────────────────────────────"
    printf "  Saving to:  %s\n" "$(dim "$TARGET_DIR")"
    printf "  Folders:    %s\n" "$(dim "${months[*]}")"
    printf "  Filter:     %s\n" "$(accent "$type_filter")"
    if (( dl_photos > 0 || dl_videos > 0 )); then
        printf "  New files:  %s photos, %s videos (from last scan)\n" "$(bold "$dl_photos")" "$(bold "$dl_videos")"
        printf "  Est. size:  ~%s\n" "$(bold "${est_mb} MB")"
    else
        dim "  icloudpd will download any missing files for the selected months."; echo
        dim "  File counts unknown — run Sync first for an estimate."; echo
    fi
    printf "  Disk free:  %s\n" "$(bold "$(humanize "$DISK_AVAIL")")"
    echo "  ────────────────────────────────────"

    if (( est_mb * 1048576 > DISK_AVAIL )); then
        err "  WARNING: Estimated download may exceed available disk space!"
    fi

    echo
    dim "  Press Y or Enter to start downloading, N to cancel."; echo
    read -rp "  Proceed? [Y/n] " confirm
    case "$confirm" in
        [nN]*) info "Cancelled. Returning to menu."; main_menu; return ;;
    esac

    echo
    dim "  Downloading... press Ctrl+C to stop safely (already-saved files are kept)."; echo
    dim "  Note: files you deleted locally will be re-downloaded if they still exist in iCloud."; echo
    echo
    download_selection "$type_filter" "${months[@]}"
    echo
    info "Download complete!"
    main_menu
}

# ── Download ──────────────────────────────────────────────────────────────────

# Merge sorted YYYY/MM values into contiguous date ranges (START:END pairs).
# This reduces the number of icloudpd invocations for adjacent months.
merge_ranges() {
    local -a months=("$@")
    if [[ ${#months[@]} -eq 0 ]]; then return; fi

    local range_start="${months[0]}"
    local range_end="${months[0]}"

    for (( i=1; i<${#months[@]}; i++ )); do
        local prev_yr="${range_end%%/*}" prev_mo="${range_end##*/}"
        local cur="${months[$i]}"
        local next_mo next_yr
        next_mo=$(printf '%02d' $(( 10#$prev_mo + 1 )))
        next_yr=$prev_yr
        if [[ "$next_mo" == "13" ]]; then
            next_mo="01"
            next_yr=$(( prev_yr + 1 ))
        fi

        if [[ "$cur" == "$next_yr/$next_mo" ]]; then
            range_end="$cur"
        else
            echo "${range_start}:${range_end}"
            range_start="$cur"
            range_end="$cur"
        fi
    done
    echo "${range_start}:${range_end}"
}

download_selection() {
    local type_filter=$1; shift
    local -a months=("$@")

    mapfile -t months < <(printf '%s\n' "${months[@]}" | sort)

    local -a ranges
    mapfile -t ranges < <(merge_ranges "${months[@]}")

    local type_flags=()
    case "$type_filter" in
        photos) type_flags=(--skip-videos --skip-live-photos) ;;
        videos) type_flags=(--skip-photos) ;;
    esac

    for range in "${ranges[@]}"; do
        local start_ym="${range%%:*}"
        local end_ym="${range##*:}"
        local start_yr="${start_ym%%/*}" start_mo="${start_ym##*/}"
        local end_yr="${end_ym%%/*}" end_mo="${end_ym##*/}"

        local start_date="${start_yr}-${start_mo}-01"
        local end_day
        end_day=$(last_day_of_month "$end_yr" "$end_mo")
        local end_date="${end_yr}-${end_mo}-${end_day}"

        info "Downloading $start_ym to $end_ym ..."

        # Run icloudpd in background — it enumerates the full library silently
        # before downloading, so we show a spinner during that wait.
        ensure_cache
        local dl_log="$CACHE_DIR/download.log"
        > "$dl_log"
        "$ICLOUDPD" \
            --log-level info \
            --username "$USERNAME" \
            --directory "$TARGET_DIR" \
            --folder-structure "$FOLDER_STRUCTURE" \
            --size "$DL_SIZE" \
            --skip-created-before "$start_date" \
            --skip-created-after "$end_date" \
            ${type_flags[@]+"${type_flags[@]}"} >> "$dl_log" 2>&1 &
        local dl_pid=$!
        BG_PID=$dl_pid

        # Spinner while icloudpd enumerates the library (no Downloaded lines yet)
        local tty=/dev/tty
        local frames='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
        local si=0 dl_started=false
        tput civis > "$tty" 2>/dev/null || true
        local dl_start_ts
        dl_start_ts=$(date +%s)

        while kill -0 "$dl_pid" 2>/dev/null; do
            # Check if downloads have started
            if grep -q "Downloaded\|Skipping\|already exists" "$dl_log" 2>/dev/null; then
                dl_started=true
                printf '\r\033[K' > "$tty"
                tput cnorm > "$tty" 2>/dev/null || true
                break
            fi

            local now_ts elapsed_s elapsed_fmt
            now_ts=$(date +%s)
            elapsed_s=$(( now_ts - dl_start_ts ))
            if (( elapsed_s >= 60 )); then
                elapsed_fmt="$(( elapsed_s / 60 ))m$(( elapsed_s % 60 ))s"
            else
                elapsed_fmt="${elapsed_s}s"
            fi

            printf '\r\033[K  \033[38;2;95;138;114m%s\033[0m Scanning iCloud library... \033[2m[%s]\033[0m' \
                "${frames:si%${#frames}:1}" "$elapsed_fmt" > "$tty"
            si=$((si + 1))
            sleep 0.08
        done

        tput cnorm > "$tty" 2>/dev/null || true

        if $dl_started; then
            # Stream the rest of the log as it appears, cleaning up icloudpd output
            local last_line=0
            while kill -0 "$dl_pid" 2>/dev/null || (( $(wc -l < "$dl_log") > last_line )); do
                local total_lines
                total_lines=$(wc -l < "$dl_log")
                if (( total_lines > last_line )); then
                    sed -n "$(( last_line + 1 )),${total_lines}p" "$dl_log" \
                        | { grep -v "Downloading [0-9]* original\|Looking up\|Processing user\|Authenticat" || true; } \
                        | gawk -v prefix="$TARGET_DIR/" '{while ((i=index($0,prefix))>0) $0=substr($0,1,i-1) substr($0,i+length(prefix)); sub(/^.*INFO */, "  "); sub(/^.*DEBUG */, "  "); print}'
                    last_line=$total_lines
                fi
                sleep 0.2
            done
        fi

        wait "$dl_pid" 2>/dev/null || true; BG_PID=""
        capture_library_total "$dl_log"
    done
}

action_sync() {
    local cli_depth="${1:-}"  # from CLI arg, e.g. icloudpd-tui 100
    local local_count
    local_count=$(find "$TARGET_DIR" -type f 2>/dev/null | wc -l)
    local library_total
    library_total=$(get_library_total)

    echo
    accent "  Sync iCloud Photos"; echo
    echo "  ────────────────────────────────────"
    TARGET_DIR=$(pick_directory "$TARGET_DIR") || { main_menu; return; }
    echo

    local missing=0
    if [[ "$library_total" =~ ^[0-9]+$ ]] && (( library_total > 0 )); then
        missing=$(( library_total - local_count ))
        local local_bytes
        local_bytes=$(du_bytes "$TARGET_DIR") || local_bytes=0
        printf "  Backed up:    %s of ~%s files (%s)\n" "$(bold "$local_count")" "$(bold "$library_total")" "$(humanize "$local_bytes")"

        if (( missing > 0 )); then
            local est_bytes
            est_bytes=$(estimate_missing_bytes "$missing")
            printf "  Missing:      ~%s files (~%s)\n" "$(bold "$missing")" "$(humanize "$est_bytes")"

            disk_info
            printf "  Disk free:    %s\n" "$(bold "$(humanize "$DISK_AVAIL")")"

            if (( est_bytes > DISK_AVAIL )); then
                local shortfall=$(( est_bytes - DISK_AVAIL ))
                echo
                printf '  \033[33m⚠ Not enough space for all missing files.\033[0m\n'
                printf '  \033[33m  Need ~%s more. Will download as much as possible.\033[0m\n' "$(humanize "$shortfall")"
            fi
        else
            printf "  Status:       %s\n" "$(accent "fully synced")"
        fi
    else
        printf "  Backed up:    %s files\n" "$(bold "$local_count")"
        dim "  iCloud library size unknown — will be detected during sync."; echo
    fi

    echo
    echo "  ────────────────────────────────────"

    # Choose sync mode
    local scan_depth
    if [[ -n "$cli_depth" ]]; then
        scan_depth=$cli_depth
        dim "  Sync with scan depth $scan_depth (from command line)"; echo
    elif (( missing > 1000 )); then
        echo
        dim "  Choose sync mode:"; echo
        echo
        printf "  $(bold "1)") Quick — check recent files only (fast, ~1 min)\n"
        printf "  $(bold "2)") Full  — check entire library (slow, may take hours)\n"
        echo
        read -rp "  Mode [1]: " mode_input
        case "$mode_input" in
            2)
                scan_depth="${library_total:-$local_count}"
                (( scan_depth < 1000 )) && scan_depth=1000
                dim "  Full sync — scanning entire library (depth: $scan_depth)"; echo
                ;;
            *)
                scan_depth=500
                dim "  Quick sync — checking recent files (depth: $scan_depth)"; echo
                ;;
        esac
    elif [[ -z "$library_total" ]] || ! [[ "$library_total" =~ ^[0-9]+$ ]]; then
        # Unknown library size — use higher depth on first sync to discover more
        scan_depth=1000
        dim "  First sync — scanning last $scan_depth files to detect library size"; echo
    else
        scan_depth=500
        dim "  Quick sync — checking recent files (depth: $scan_depth)"; echo
    fi

    echo
    read -rp "  Start download? [Y/n] " confirm
    case "$confirm" in
        [nN]*) info "Cancelled."; main_menu; return ;;
    esac

    echo
    dim "  Downloading... press Q or Ctrl+C to stop safely (progress is kept)."; echo
    echo

    # Run icloudpd in background with live status display
    ensure_cache
    local sync_log="$CACHE_DIR/sync.log"
    > "$sync_log"

    "$ICLOUDPD" \
        --username "$USERNAME" \
        --directory "$TARGET_DIR" \
        --folder-structure "$FOLDER_STRUCTURE" \
        --size "$DL_SIZE" \
        --until-found "$scan_depth" >> "$sync_log" 2>&1 &
    local sync_pid=$!
    BG_PID=$sync_pid

    local tty=/dev/tty
    local checked=0 downloaded=0 skipped=0
    local frames='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    local fi=0 last_line_count=0
    local start_ts
    start_ts=$(date +%s)
    local -a recent_files=("" "" "" "" "")
    local display_rows=7

    tput civis > "$tty" 2>/dev/null || true
    for ((r=0; r<display_rows; r++)); do printf '\n' > "$tty"; done

    # Enable non-blocking key reading for Q to quit
    if [[ -t 0 ]]; then stty -echo -icanon time 0 min 0 2>/dev/null || true; fi

    while kill -0 "$sync_pid" 2>/dev/null; do
        # Check for Q key press
        local keypress=""
        read -rsn1 -t 0.01 keypress 2>/dev/null || true
        if [[ "$keypress" == "q" || "$keypress" == "Q" ]]; then
            kill "$sync_pid" 2>/dev/null || true
            wait "$sync_pid" 2>/dev/null || true; BG_PID=""
            break
        fi
        local total_lines
        total_lines=$(wc -l < "$sync_log" 2>/dev/null) || total_lines=0

        if (( total_lines > last_line_count )); then
            local batch_result
            batch_result=$(sed -n "$(( last_line_count + 1 )),${total_lines}p" "$sync_log" \
                | gawk -v tdir="$TARGET_DIR" '
                /Downloaded/ {
                    idx = index($0, tdir "/")
                    if (idx) $0 = substr($0, idx + length(tdir) + 1)
                    gsub(/[[:space:]].*/, "")
                    dl++; print "new|" $0
                }
                /already exists|deduplicated/ {
                    idx = index($0, tdir "/")
                    if (idx) $0 = substr($0, idx + length(tdir) + 1)
                    gsub(/[[:space:]].*/, "")
                    sk++; print "ok|" $0
                }
                END { print "COUNTS|" dl+0 "|" sk+0 }
            ')
            last_line_count=$total_lines

            local counts_line
            counts_line=$(echo "$batch_result" | tail -1)
            local dl_new skip_new
            dl_new=$(echo "$counts_line" | cut -d'|' -f2)
            skip_new=$(echo "$counts_line" | cut -d'|' -f3)
            downloaded=$(( downloaded + dl_new ))
            skipped=$(( skipped + skip_new ))
            checked=$(( downloaded + skipped ))

            local -a batch_files
            mapfile -t batch_files < <({ echo "$batch_result" | grep -v "^COUNTS|" || true; } | tail -5)
            for entry in "${batch_files[@]}"; do
                [[ -n "$entry" ]] && recent_files=("${recent_files[@]:1}" "$entry")
            done
        fi

        local now_ts elapsed_s elapsed_fmt
        now_ts=$(date +%s)
        elapsed_s=$(( now_ts - start_ts ))
        if (( elapsed_s >= 60 )); then
            elapsed_fmt="$(( elapsed_s / 60 ))m$(( elapsed_s % 60 ))s"
        else
            elapsed_fmt="${elapsed_s}s"
        fi

        printf '\033[%dA' "$display_rows" > "$tty"

        for ((r=0; r<5; r++)); do
            local entry="${recent_files[$r]}"
            if [[ -n "$entry" ]]; then
                local st="${entry%%|*}"
                local fn="${entry#*|}"
                fn="${fn:0:65}"
                if [[ "$st" == "new" ]]; then
                    printf '\033[K    \033[32m+ %s\033[0m\n' "$fn" > "$tty"
                else
                    printf '\033[K    \033[2m✓ %s\033[0m\n' "$fn" > "$tty"
                fi
            else
                printf '\033[K\n' > "$tty"
            fi
        done

        printf '\033[K  \033[38;2;95;138;114m%s\033[0m  checked \033[1m%d\033[0m  new \033[1;32m%d\033[0m  skipped \033[2m%d\033[0m  \033[2m[%s]\033[0m\n' \
            "${frames:fi%${#frames}:1}" "$checked" "$downloaded" "$skipped" "$elapsed_fmt" > "$tty"
        printf '\033[K\n' > "$tty"

        fi=$(( fi + 1 ))
        sleep 0.1
    done

    # Final count
    local total_lines
    total_lines=$(wc -l < "$sync_log" 2>/dev/null) || total_lines=0
    if (( total_lines > last_line_count )); then
        local new_lines
        new_lines=$(sed -n "$(( last_line_count + 1 )),${total_lines}p" "$sync_log")
        local dl_new skip_new
        dl_new=$(echo "$new_lines" | grep -c "Downloaded" 2>/dev/null) || dl_new=0
        skip_new=$(echo "$new_lines" | grep -c "already exists\|deduplicated" 2>/dev/null) || skip_new=0
        downloaded=$(( downloaded + dl_new ))
        skipped=$(( skipped + skip_new ))
        checked=$(( downloaded + skipped ))
    fi

    wait "$sync_pid" 2>/dev/null || true; BG_PID=""

    printf '\033[%dA' "$display_rows" > "$tty"
    for ((r=0; r<display_rows; r++)); do printf '\033[K\n' > "$tty"; done
    printf '\033[%dA' "$display_rows" > "$tty"

    tput cnorm > "$tty" 2>/dev/null || true
    # Restore terminal input mode
    if [[ -t 0 ]]; then stty echo icanon 2>/dev/null || true; fi
    capture_library_total "$sync_log"

    echo
    accent "  Sync complete"; echo
    echo "  ────────────────────────────────────"
    printf "  Checked:      %s files\n" "$(bold "$checked")"
    printf "  Downloaded:   %s new files\n" "$(bold "$downloaded")"
    printf "  Skipped:      %s already backed up\n" "$(dim "$skipped")"
    echo "  ────────────────────────────────────"
    if [[ "${CLI_MODE:-}" == "true" ]]; then
        echo
        exit 0
    fi
    echo
    read -rp "  $(dim "Press Enter to go back to menu...") " _
    main_menu
}

action_settings() {
    echo
    accent "  Settings"; echo
    echo "  ────────────────────────────────────"
    printf "  Apple ID:      %s\n" "$(bold "$USERNAME")"
    printf "  Directory:     %s\n" "$(bold "$TARGET_DIR")"
    [[ -n "$MOUNT_POINT" ]] && printf "  Drive check:   %s\n" "$(bold "$MOUNT_POINT")"
    echo "  ────────────────────────────────────"
    echo

    local choice
    choice=$(printf '%s\n' \
        "  Change Apple ID" \
        "  Change download location" \
        "  Re-run full setup" \
        "  Back to menu" \
    | fzf --ansi --no-multi --no-sort --reverse \
        --color="$FZF_COLORS" \
        --prompt="  " --pointer="▸" \
        --header="$(dim "  Select an option, or Esc to go back")" \
        --header-first \
    || echo "Back")

    case "$choice" in
        *"Change Apple ID"*)
            local default_user="$USERNAME"
            while true; do
                read -rp "  New Apple ID [$default_user]: " input
                input="${input:-$default_user}"
                if [[ "$input" == *@*.* ]]; then
                    USERNAME="$input"
                    save_config
                    info "Apple ID updated. You may need to re-authenticate."
                    break
                else
                    err "  That doesn't look like an email address."
                fi
            done
            ;;
        *"Change download location"*)
            local new_dir
            new_dir=$(pick_directory "$TARGET_DIR")
            if [[ "$new_dir" != "$TARGET_DIR" ]]; then
                TARGET_DIR="$new_dir"
                save_config
                info "Download location updated to $TARGET_DIR"
            fi
            ;;
        *"Re-run full setup"*)
            run_setup
            ;;
    esac
    echo
    main_menu
}

action_logout() {
    echo
    accent "  Log Out"; echo
    echo "  ────────────────────────────────────"
    dim "  This will:"; echo
    dim "  - Clear your iCloud session cookies"; echo
    dim "  - Remove your saved config (Apple ID, paths)"; echo
    dim "  - Remove scan cache"; echo
    echo
    dim "  Your downloaded photos will NOT be deleted."; echo
    echo
    read -rp "  Are you sure? [y/N] " confirm
    case "$confirm" in
        [yY]*)
            # Clear all icloudpd session cookies
            rm -rf "$HOME/.pyicloud" 2>/dev/null
            info "Cleared iCloud session"

            # Clear config and cache
            rm -f "$CONFIG_FILE" 2>/dev/null
            rm -rf "$CACHE_DIR" 2>/dev/null
            info "Cleared config and cache"

            echo
            info "Logged out. Run icloudpd-tui again to set up a new account."
            exit 0
            ;;
        *)
            info "Cancelled."
            main_menu
            return
            ;;
    esac
}

action_disk_status() {
    disk_info
    calibrate_averages

    echo
    accent "  Disk Status"; echo
    echo "  ────────────────────────────────────"
    printf "  Target:      %s\n" "$(dim "$TARGET_DIR")"
    [[ -n "$MOUNT_POINT" ]] && printf "  Drive:       %s\n" "$(dim "$MOUNT_POINT")"
    echo

    # Visual usage bar
    local pct_num=${DISK_PCT%\%}
    local avail_gb=$(( DISK_AVAIL / 1073741824 ))
    local bar_width=20
    local filled=$(( pct_num * bar_width / 100 ))
    local empty=$(( bar_width - filled ))
    local bar=""
    for ((b=0; b<filled; b++)); do bar+="█"; done
    for ((b=0; b<empty; b++)); do bar+="░"; done

    local bar_color
    if (( avail_gb < 2 )); then bar_color="31";        # red
    elif (( avail_gb < 10 )); then bar_color="33";      # yellow
    else bar_color="38;2;95;138;114";                    # accent green
    fi
    printf "  Usage:       \033[${bar_color}m[%s]\033[0m %s\n" "$bar" "$DISK_PCT"

    printf "  Total:       %s\n" "$(bold "$(humanize "$DISK_TOTAL")")"
    printf "  Used:        %s\n" "$(humanize "$DISK_USED")"

    if (( avail_gb < 2 )); then
        printf "  Available:   %s  \033[31malmost full!\033[0m\n" "$(bold "$(humanize "$DISK_AVAIL")")"
    elif (( avail_gb < 10 )); then
        printf "  Available:   %s  \033[33m⚠ running low\033[0m\n" "$(bold "$(humanize "$DISK_AVAIL")")"
    else
        printf "  Available:   %s\n" "$(bold "$(humanize "$DISK_AVAIL")")"
    fi
    echo "  ────────────────────────────────────"

    local local_count=0 pending=0
    if [[ -d "$TARGET_DIR" ]]; then
        local_count=$(find "$TARGET_DIR" -type f 2>/dev/null | wc -l)
    fi
    if [[ -f "$CACHE_FILE" ]]; then
        pending=$(wc -l < "$CACHE_FILE")
    fi

    printf "  Backed up:   %s files\n" "$(bold "$local_count")"

    if (( pending > 0 )); then
        # Estimate space needed for pending files
        local pending_photos=0 pending_videos=0
        if [[ -f "$CACHE_DIR/tree.txt" ]]; then
            while IFS='|' read -r type _ _ _ _ pp pv; do
                if [[ "$type" == "M" ]]; then
                    pending_photos=$((pending_photos + pp))
                    pending_videos=$((pending_videos + pv))
                fi
            done < "$CACHE_DIR/tree.txt"
        fi
        local est_mb
        est_mb=$(estimate_size_mb "$pending_photos" "$pending_videos")
        printf "  Pending:     %s files (~%s MB needed)\n" "$(bold "$pending")" "$est_mb"

        echo
        local est_bytes=$(( est_mb * 1048576 ))
        if (( est_bytes > DISK_AVAIL )); then
            printf "  \033[31mNot enough space for pending downloads.\033[0m\n"
            dim "  Free up space or download selectively via Browse & Download."; echo
        else
            printf "  $(accent "Enough space for pending downloads.")\n"
        fi
    else
        if [[ -f "$CACHE_FILE" ]]; then
            printf "  Pending:     %s\n" "$(accent "none — up to date (from last scan)")"
        else
            printf "  Pending:     %s\n" "$(dim "unknown — run Sync to check")"
        fi
    fi

    echo "  ────────────────────────────────────"
    echo
    read -rp "  $(dim "Press Enter to go back to menu...") " _
    main_menu
}

# ── Main ──────────────────────────────────────────────────────────────────────

main() {
    # Handle flags
    case "${1:-}" in
        --help|-h)    show_help ;;
        --version|-v) show_version ;;
        --setup)      check_deps; load_config; banner; run_setup; exit 0 ;;
    esac

    check_deps
    ensure_config
    # Banner is shown by ensure_config on first run; skip if already shown
    [[ "${SETUP_AUTH_DONE:-}" == "true" || "${SETUP_AUTH_DONE:-}" == "false" ]] || banner
    check_mount

    # Backward compatibility: numeric arg triggers quick sync and exits
    if [[ "${1:-}" =~ ^[0-9]+$ ]]; then
        CLI_MODE=true
        action_sync "$1"
        return
    fi

    # Skip auth if setup already did it
    if [[ "${SETUP_AUTH_DONE:-}" == "true" ]]; then
        SETUP_AUTH_DONE=""
    else
        info "Signing in to iCloud..."
        dim "  If prompted, enter your Apple ID password and the verification code"; echo
        dim "  sent to your trusted Apple devices."; echo
        echo
        if ! "$ICLOUDPD" --auth-only --username "$USERNAME"; then
            echo
            err "  Authentication failed."
            dim "  This could be a wrong Apple ID, expired session, or network issue."; echo
            echo
            read -rp "  $(dim "Run setup to change account? [y/N]") " fix
            case "$fix" in
                [yY]*) run_setup; exit 0 ;;
                *) exit 1 ;;
            esac
        fi
        echo
    fi

    main_menu
}

main "$@"
